{
  "name": "SaoHua Committer",
  "url": "https://github.com/justlovemaki/git-commit-sao-hua",
  "description": "自动用骚话评论 PR 和 Issue 的 GitHub App",
  "public": false,
  "redirect_url": "https://github.com/justlovemaki/git-commit-sao-hua/github-app",
  "hook_attributes": {
    "url": "https://your-server.com/",
    "active": true
  },
  "permissions": {
    "issues": "write",
    "pull_requests": "write",
    "contents": "read"
  },
  "events": [
    "pull_request",
    "issues"
  ]
}
