{
  "name": "git-commit-sao-hua",
  "displayName": "Git Commit 骚话生成器",
  "description": "让每次 Git 提交都充满爱意（或骚气）！支持 12 种类型 × 5 种风格",
  "version": "1.5.0",
  "publisher": "coding-expert",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "keywords": [
    "git",
    "commit",
    "骚话",
    "情话",
    "commit message"
  ],
  "activationEvents": [
    "onCommand:gitCommitSaoHua.generate",
    "onCommand:gitCommitSaoHua.generateRandom",
    "onCommand:gitCommitSaoHua.generateSmart",
    "onCommand:gitCommitSaoHua.selectType",
    "onCommand:gitCommitSaoHua.selectStyle",
    "onCommand:gitCommitSaoHua.resetPreferences",
    "onCommand:gitCommitSaoHua.clearDescriptionHistory",
    "onCommand:gitCommitSaoHua.openKeybindings",
    "onCommand:gitCommitSaoHua.manageCustomSaoHua",
    "onCommand:gitCommitSaoHua.addCustomSaoHua",
    "onCommand:gitCommitSaoHua.clearCustomSaoHua",
    "onCommand:gitCommitSaoHua.showStatistics"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitCommitSaoHua.generate",
        "title": "生成骚话 Commit",
        "category": "Git Commit 骚话"
      },
      {
        "command": "gitCommitSaoHua.generateRandom",
        "title": "随机生成 Commit",
        "category": "Git Commit 骚话"
      },
      {
        "command": "gitCommitSaoHua.generateSmart",
        "title": "智能检测生成 Commit",
        "category": "Git Commit 骚话"
      },
      {
        "command": "gitCommitSaoHua.selectType",
        "title": "选择 Commit 类型",
        "category": "Git Commit 骚话"
      },
      {
        "command": "gitCommitSaoHua.selectStyle",
        "title": "选择风格模式",
        "category": "Git Commit 骚话"
      },
      {
        "command": "gitCommitSaoHua.resetPreferences",
        "title": "重置类型/风格偏好",
        "category": "Git Commit 骚话"
      },
      {
        "command": "gitCommitSaoHua.clearDescriptionHistory",
        "title": "清空描述历史",
        "category": "Git Commit 骚话"
      },
      {
        "command": "gitCommitSaoHua.openKeybindings",
        "title": "打开快捷键设置",
        "category": "Git Commit 骚话"
      },
      {
        "command": "gitCommitSaoHua.manageCustomSaoHua",
        "title": "管理自定义骚话",
        "category": "Git Commit 骚话"
      },
      {
        "command": "gitCommitSaoHua.addCustomSaoHua",
        "title": "添加自定义骚话",
        "category": "Git Commit 骚话"
      },
      {
        "command": "gitCommitSaoHua.clearCustomSaoHua",
        "title": "清空自定义骚话",
        "category": "Git Commit 骚话"
      },
      {
        "command": "gitCommitSaoHua.showStatistics",
        "title": "查看使用统计",
        "category": "Git Commit 骚话"
      }
    ],
    "configuration": {
      "title": "Git Commit 骚话生成器",
      "properties": {
        "gitCommitSaoHua.defaultStyle": {
          "type": "string",
          "enum": [
            "love",
            "sao",
            "zha",
            "chu",
            "fo"
          ],
          "default": "sao",
          "description": "默认风格：情话(love)/骚话(sao)/扎心(zha)/中二(chu)/佛系(fo)"
        },
        "gitCommitSaoHua.defaultType": {
          "type": "string",
          "enum": [
            "fix",
            "feat",
            "chore",
            "docs",
            "refactor",
            "style",
            "test",
            "perf",
            "ci",
            "build",
            "revert",
            "hotfix"
          ],
          "default": "feat",
          "description": "默认 Commit 类型"
        },
        "gitCommitSaoHua.autoInsert": {
          "type": "boolean",
          "default": true,
          "description": "自动插入到 Git input box"
        },
        "gitCommitSaoHua.enableSoundEffects": {
          "type": "boolean",
          "default": true,
          "description": "启用音效反馈（通过状态栏消息和通知实现）"
        },
        "gitCommitSaoHua.customSaoHuaProbability": {
          "type": "number",
          "default": 0.3,
          "minimum": 0,
          "maximum": 1,
          "description": "使用自定义骚话的概率（0-1 之间，默认 0.3 表示 30% 概率）"
        },
        "gitCommitSaoHua.maxHistoryCount": {
          "type": "integer",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "描述历史记录最大保存数量（默认 10 条）"
        },
        "gitCommitSaoHua.enableSmartDetection": {
          "type": "boolean",
          "default": true,
          "description": "启用智能检测功能（自动分析 Git 变更推荐 Commit 类型）"
        },
        "gitCommitSaoHua.astAnalysisEnabled": {
          "type": "boolean",
          "default": true,
          "description": "启用 AST 代码结构分析（检测函数/类/CSS 变更）"
        },
        "gitCommitSaoHua.showConfidenceDetail": {
          "type": "boolean",
          "default": true,
          "description": "显示智能检测的置信度详情信息"
        }
      }
    },
    "keybindings": [
      {
        "command": "gitCommitSaoHua.generateRandom",
        "key": "ctrl+shift+g",
        "when": "editorTextFocus"
      },
      {
        "command": "gitCommitSaoHua.showStatistics",
        "key": "ctrl+shift+s",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "check": "node -e \"const fs=require('fs'); const required=['extension.js','sao-hua-data.js','README.md','LICENSE','icon.png']; const missing=required.filter(f=>!fs.existsSync(f)); if(missing.length){console.error('Missing required files:', missing.join(', ')); process.exit(1);} console.log('Extension files look good.');\"",
    "package": "npx @vscode/vsce package --out git-commit-sao-hua.vsix",
    "package:ci": "npm run check && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/justlovemaki/git-commit-sao-hua.git"
  },
  "bugs": {
    "url": "https://github.com/justlovemaki/git-commit-sao-hua/issues"
  },
  "license": "MIT",
  "icon": "icon.png",
  "devDependencies": {
    "@vscode/vsce": "^3.7.1"
  }
}
